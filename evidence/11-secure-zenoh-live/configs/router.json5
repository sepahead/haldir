        ],
        "permission": "allow"
      }
    ],
    "subjects": [
      {
        "cert_common_names": [
          "haldir-admission-authority.secure-reference-v1"
        ],
        "id": "admission-authority"
      },
      {
        "cert_common_names": [
          "haldir-controller-a.secure-reference-v1"
        ],
        "id": "controller-a"
      },
      {
        "cert_common_names": [
          "haldir-controller-b.secure-reference-v1"
        ],
        "id": "controller-b"
      },
      {
        "cert_common_names": [
          "haldir-gate.secure-reference-v1"
        ],
        "id": "gate"
      },
      {
        "cert_common_names": [
          "haldir-lifecycle.secure-reference-v1"
        ],
        "id": "lifecycle"
      },
      {
        "cert_common_names": [
          "haldir-mission-authority.secure-reference-v1"
        ],
        "id": "mission-authority"
      },
      {
        "cert_common_names": [
          "haldir-observer.secure-reference-v1"
        ],
        "id": "observer"
      },
      {
        "cert_common_names": [
          "haldir-robot-crebain.secure-reference-v1"
        ],
        "id": "robot-crebain"
      }
    ]
  },
  "adminspace": {
    "enabled": false
  },
  "connect": {
    "endpoints": []
  },
  "listen": {
    "endpoints": [
      "tls/0.0.0.0:7447"
    ],
    "exit_on_failure": true
  },
  "mode": "router",
  "plugins": {},
  "plugins_loading": {
    "enabled": false
  },
  "scouting": {
    "gossip": {
      "enabled": false
    },
    "multicast": {
      "enabled": false
    }
  },
  "transport": {
    "link": {
      "rx": {
        "buffer_size": 65535,
        "max_message_size": 32768
      },
      "tls": {
        "close_link_on_expiration": true,
        "enable_mtls": true,
        "listen_certificate": "/run/secrets/haldir-secure-reference-v1/router.cert.pem",
        "listen_private_key": "/run/secrets/haldir-secure-reference-v1/router.key.pem",
        "root_ca_certificate": "/run/secrets/haldir-secure-reference-v1/ca.pem"
      },
      "tx": {
        "queue": {
          "congestion_control": {
            "block": {
              "wait_before_close": 50000
            }
          }
        }
      }
    },
    "shared_memory": {
      "enabled": false
    }
  }
}
